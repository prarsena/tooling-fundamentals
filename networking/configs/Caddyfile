# =============================================================================
# networking/configs/Caddyfile
# Local HTTPS reverse proxy — Caddy 2 configuration.
#
# Usage:
#   caddy run --config configs/Caddyfile          # foreground (dev)
#   caddy start --config configs/Caddyfile        # background daemon
#   caddy stop                                    # stop daemon
#   caddy reload --config configs/Caddyfile       # hot-reload (no downtime)
#
# Caddy handles TLS automatically when using a public domain.
# For local .local domains, provide certs from mkcert or step-ca.
#
# Docs: https://caddyserver.com/docs/caddyfile
# =============================================================================

{
    # ---- Global options ----
    # Use HTTP/3 (QUIC) alongside HTTP/1.1 and HTTP/2.
    # Supported natively in macOS Safari and Chrome — no flags needed.
    servers {
        protocols h1 h2 h3
    }

    # Limit the admin API to localhost only (default: localhost:2019).
    # The admin API lets you reload config and inspect running state without
    # restarting the process. Do NOT expose to non-loopback interfaces.
    admin localhost:2019
}

# =============================================================================
# Example 1: Reverse proxy for a local service
# Replace myapp.local with your chosen .local hostname.
# Prerequisite: add `127.0.0.1  myapp.local` to /etc/hosts
#
# Generate TLS cert with mkcert:
#   mkcert myapp.local
#   # produces: myapp.local.pem  myapp.local-key.pem
#
# Or with step-ca (if running):
#   step ca certificate myapp.local myapp.local.pem myapp.local-key.pem \
#     --ca-url https://127.0.0.1:9000
# =============================================================================
myapp.local {
    # Reference the TLS cert/key generated by mkcert or step-ca.
    # Caddy does NOT auto-manage certs for .local domains — you must
    # supply them explicitly via the tls directive.
    tls /path/to/myapp.local.pem /path/to/myapp.local-key.pem

    # Proxy all traffic to a backend process on port 8080.
    reverse_proxy localhost:8080

    # Structured access log — stored in macOS-standard Logs location.
    # Directory must exist: mkdir -p ~/Library/Logs/caddy
    log {
        output file {env.HOME}/Library/Logs/caddy/myapp.access.log {
            roll_size 10mb
            roll_keep 5
        }
        format json
    }
}

# =============================================================================
# Example 2: Serve static files from a local directory
#
# Replace files.local with your chosen hostname and /path/to/dir with
# the directory to serve. TLS setup is the same as example 1.
# =============================================================================
# files.local {
#     tls /path/to/files.local.pem /path/to/files.local-key.pem
#     root * /path/to/your/directory
#     file_server browse
# }

